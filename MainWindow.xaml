<Window x:Class="GameChronometer.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"        
        Title="GameChronometer"
        Height="155" Width="238"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        Topmost="True"
        ResizeMode="NoResize"
        Left="20" Top="20">

    <Grid>
        <Grid.Resources>
            <Style TargetType="Button">
                <Setter Property="Background" Value="#33ffffff"/>
                <Setter Property="BorderThickness" Value="0"/>
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="Button">
                            <Border Background="{TemplateBinding Background}"
                                    CornerRadius="14"
                                    Padding="8,4">
                                <ContentPresenter HorizontalAlignment="Center"
                                                  VerticalAlignment="Center"/>
                            </Border>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>
        </Grid.Resources>

        <Border Background="#33000000"
                CornerRadius="12"
                Padding="16" Margin="13,7,13,7">
            <StackPanel Margin="0,20,0,19">
                <TextBlock x:Name="TimeDisplay"
                           Text="00:00:00"
                           FontSize="36"
                           FontWeight="Bold"
                           Foreground="#CCffffff"
                           FontFamily="Consolas" Height="35" RenderTransformOrigin="0.311,0.459" Width="160"/>
                <StackPanel Orientation="Horizontal"
                            Height="35" Width="160" RenderTransformOrigin="0.5,0.5">
                    

                    <Button x:Name="PlayPauseBtn"
                            Content="Play"
                            Foreground="#CCffffff"
                            Width="70"
                            Margin="4,0"
                            Click="PlayPauseBtn_Click" Height="22" />
                    <Button x:Name="ResetBtn"
                            Content="Reset"
                            Foreground="#CCffffff"
                            Width="70"
                            Margin="4,0"
                            Click="ResetBtn_Click" Height="24" />

                </StackPanel>
            </StackPanel>
        </Border>
    </Grid>
</Window>
